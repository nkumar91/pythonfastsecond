# DATABASE_URL=mysql+mysqlconnector://root:1234@localhost:3306/test
#DB_HOST=host.docker.internal
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=fastapi
DB_URL=mysql+mysqlconnector://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}
SECRET_KEY=your_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30


# SERVER CONFIG
SERVER_HOST=127.0.0.1
SERVER_PORT=8000
ENVIRONMENT=development
DEBUG=True


ALLOWED_TYPES=["image/jpeg", "image/png"]
MAX_FILE_SIZE=2097152

